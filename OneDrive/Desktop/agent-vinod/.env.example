# Database
DATABASE_URL=sqlite:///./agentic_demo_brain.db

# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=demo_brain

# LiveKit (voice sessions)
LIVEKIT_URL=ws://localhost:7880
LIVEKIT_API_KEY=devkey
LIVEKIT_API_SECRET=devsecret

# LLM providers (optional - falls back to Ollama if unset)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# Encryption key for credentials (generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=your-fernet-key-here

# Browser automation
PLAYWRIGHT_HEADLESS=true
ENABLE_BROWSER_USE_FALLBACK=false

# Voice
ENABLE_VOICE=false

# Sandbox defaults
DEFAULT_ALLOWED_DOMAIN=localhost
SESSION_TIMEOUT_SECONDS=1800

# App
APP_ENV=development
LOG_LEVEL=INFO
BACKEND_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000
